
@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
title Back-End Module - C4 Level 1 Context
LAYOUT_LEFT_RIGHT()

Person(user, "User", "Triggers requests through UI")
Person(admin, "Admin", "Monitors and manages platform")

System(backend, "Back-End Module", "Business logic for Socially")

System_Ext(frontend, "Front-End Module", "Web application")
System_Ext(db, "Database", "Stores application data")
System_Ext(calendar, "Google Calendar API", "Availability source")
System_Ext(payment, "Payment Service", "Secure payment processing")
System_Ext(ai, "AI Engine", "Recommendation service")

Rel(frontend, backend, "Sends requests")
Rel(user, backend, "Indirectly uses")
Rel(admin, backend, "Indirectly uses")
Rel(backend, db, "Reads/Writes")
Rel(backend, calendar, "Synchronizes availability")
Rel(backend, payment, "Processes payments")
Rel(backend, ai, "Requests recommendations")
@enduml
